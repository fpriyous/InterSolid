rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. GLOBAL ADMIN ACCESS (NUCLEAR RULE)
    // This allows the DEWA (fpriyous@gmail.com) to do EVERYTHING.
    match /{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email.lower() == 'fpriyous@gmail.com'
      );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isDewa() {
      return isSignedIn() && request.auth.token.email.lower() == 'fpriyous@gmail.com';
    }

    function isAdmin() {
      return isSignedIn() && (
        isDewa() ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isMember() {
      return isSignedIn();
    }

    // 2. SPECIFIC COLLECTION RULES
    
    // Announcements
    match /announcements/{id} {
      allow read: if true;
      allow create: if isMember();
      allow update, delete: if isAdmin() || (isMember() && resource.data.authorId == request.auth.uid);
    }

    match /events/{id} {
      allow read: if true;
      allow write: if isMember();
    }

    match /notes/{id} {
      allow read: if true;
      allow create: if isMember();
      allow update: if isAdmin() || (
        isMember() && 
        resource.data.get('isLocked', false) == false &&
        request.resource.data.get('isLocked', false) == false
      );
      allow delete: if isAdmin() || (
        isMember() && 
        resource.data.get('isLocked', false) == false
      );

      match /history/{historyId} {
        allow read: if isMember();
        allow create: if isMember();
      }

      match /presence/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /polls/{id} {
      allow read: if true;
      allow create: if isMember();
      allow delete: if isAdmin();
      allow update: if isMember();
      
      match /options/{optId} {
        allow read: if true;
        allow create, delete: if isAdmin();
        allow update: if isMember();
      }
    }

    // Aspirasi
    match /aspirasi/{id} {
      allow read: if true;
      allow create: if isMember();
      allow update: if isMember(); // Reactions
      allow delete: if isAdmin();
    }

    // Attendance Tables
    match /absenTables/{id} {
      allow read: if true;
      allow create: if isMember();
      allow update: if isAdmin() || (
        isMember() && 
        resource.data.isLocked == false && 
        request.resource.data.isLocked == false
      );
      allow delete: if isAdmin();

      match /cols/{colId} {
        allow read: if true;
        allow write: if isAdmin() || (
          isMember() && 
          get(/databases/$(database)/documents/absenTables/$(id)).data.isLocked == false
        );
      }

      match /rows/{rowId} {
        allow read: if true;
        allow write: if isAdmin() || (
          isMember() && 
          get(/databases/$(database)/documents/absenTables/$(id)).data.isLocked == false
        );
      }
    }

    // Notifications
    match /notifications/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if true;
      allow update: if isAdmin();
    }

    match /admins/{id} {
      allow read, write: if isSignedIn() && request.auth.uid == id;
      allow read: if isAdmin();
    }

    // Memories (Class Moments)
    match /memories/{id} {
      allow read: if true;
      allow create: if isMember();
      allow update: if isMember() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'reactions'])
        )
      );
      allow delete: if isAdmin() || (resource.data.userId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isMember();
        allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
      }
    }

    // Portal Logs & Activity Tracking
    match /portal_logs/{id} {
      allow read: if isMember();
      allow create: if isMember();
      allow update, delete: if isAdmin();
    }

    match /spin_logs/{id} {
      allow read: if true;
      allow create: if isMember();
      allow update, delete: if isAdmin();
    }

    match /table_activity/{id} {
      allow read: if true;
      allow create: if isMember();
      allow update, delete: if isAdmin();
    }
  }
}
