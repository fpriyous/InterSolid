rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isDewa() {
      return isSignedIn() && request.auth.token.email == 'fpriyous@gmail.com';
    }

    match /{document=**} {
      allow read, write: if isDewa();
    }

    // Collection rules
    match /announcements/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /events/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /notes/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /polls/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /aspirasi/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /absenTables/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /notifications/{id} {
      allow read, write: if true;
    }
    match /admins/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /memories/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /portal_logs/{id} {
      allow read, create: if true;
      allow update, delete: if isSignedIn();
    }
    match /spin_logs/{id} {
      allow read, write: if isSignedIn();
    }
    match /table_activity/{id} {
      allow read, write: if isSignedIn();
    }
    match /test/connection {
      allow read, write: if true;
    }
  }
}
